{
  "name": "game-night",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:routes": "node scripts/check-route-exports.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "node scripts/setup-env.mjs && supabase start && supabase db reset && next dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.44.0",
    "next": "15.5.18",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.0.0",
    "postcss": "^8",
    "supabase": "^2.98.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }

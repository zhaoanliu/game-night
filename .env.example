# Local Supabase, started by `npm run setup` (or `npx supabase start`).
#
# These are the Supabase CLI's standard local demo credentials — they are the
# same on every machine, only ever reach a container on localhost, and are safe
# to commit. `npm run setup` copies this file to .env.local if you don't have
# one. Ports are offset from the Supabase defaults so this stack can run
# alongside another local Supabase project (see supabase/config.toml).
#
# A hosted deployment sets these in the Vercel project instead, pointing at a
# real Supabase project — the service role key there is a genuine secret.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
